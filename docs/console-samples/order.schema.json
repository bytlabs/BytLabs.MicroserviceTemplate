{
  "formSchema": {
    "type": "object",
    "required": ["customerName"],
    "properties": {
      "customerName": { "type": "string", "title": "Customer name" },
      "customerEmail": { "type": "string", "title": "Customer email", "format": "email" },
      "priority": { "type": "string", "title": "Priority", "enum": ["Low", "Normal", "High", "Urgent"] },
      "shippingCountry": { "type": "string", "title": "Shipping country", "enum": ["US", "CA", "UK", "DE", "IN"] },
      "totalAmount": { "type": "number", "title": "Total amount (USD)" },
      "expedited": { "type": "boolean", "title": "Expedited shipping" },
      "notes": { "type": "string", "title": "Notes" }
    }
  },
  "uiSchema": {
    "customerName": { "ui:widget": "TextWidget", "ui:placeholder": "Full name" },
    "customerEmail": { "ui:widget": "TextWidget", "ui:placeholder": "name@example.com" },
    "priority": { "ui:widget": "SelectWidget" },
    "shippingCountry": { "ui:widget": "SelectWidget" },
    "totalAmount": { "ui:widget": "UpDownWidget" },
    "expedited": { "ui:widget": "CheckboxWidget" },
    "notes": { "ui:widget": "TextareaWidget" }
  },
