          { "type": "dt", "label": "Email", "bind": "data.customerEmail" },
          { "type": "dt", "label": "Priority", "bind": "data.priority" },
          { "type": "dt", "label": "Shipping country", "bind": "data.shippingCountry" },
          { "type": "dt", "label": "Total", "bind": "data.totalAmount", "format": { "type": "number", "format": "currency", "options": { "currency": "USD", "minimumFractionDigits": 2, "maximumFractionDigits": 2 } } },
          { "type": "dt", "label": "Notes", "bind": "data.notes" }
