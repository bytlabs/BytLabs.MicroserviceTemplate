{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ObservabilityConfiguration": {
    "CollectorUrl": "http://localhost:4317",
    "ServiceName": "microservice-template",
    "Timeout": 1000
  },
  "DataStore": {
    "Provider": "Postgres"
  },
  "MongoDatabaseConfiguration": {
    "DatabaseName": "microserviceTemplate",
    "ConnectionString": "mongodb://localhost:27017?retryWrites=false",
    "UseTransactions": false
  },
  "EfDatabaseConfiguration": {
    "UseTransactions": true,
    "Tenants": [
      {
        "TenantId": "Test",
        "ConnectionString": "Host=localhost;Port=5432;Database=microservicetemplate;Username=postgres;Password=postgres"
      },
      {
        "TenantId": "default",
        "ConnectionString": "Host=localhost;Port=5432;Database=default;Username=postgres;Password=postgres"
      }
    ]
  },
  "ConsoleAuth": {
    "Mode": "Basic",
    "Basic": {
      "Username": "admin",
      "Password": "change-me",
      "JwtSigningKey": "REPLACE_WITH_A_32+_CHAR_SECRET_KEY_1234567890",
      "Issuer": "bytlabs-console",
      "ExpiryMinutes": 480
    },
    "Oidc": {
      "Authority": "",
      "ClientId": ""
    }
  }
}
